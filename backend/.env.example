DATABASE_URL="postgresql://user:password@host:5432/collect_track?schema=public"
JWT_SECRET="your-very-secret-key-change-in-production"
JWT_EXPIRES_IN="24h"
BCRYPT_SALT_ROUNDS=12
PORT=3001
FRONTEND_URL="http://localhost:5173"

# Nodemailer (SMTP)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your@email.com"
SMTP_PASS="your-app-password"
SMTP_FROM="Collect&Track <your@email.com>"

# Alertes email destinataire par défaut
ALERTE_EMAIL_DEST="manager@example.com"
